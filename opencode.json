{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "agent": {
    "plan": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "build": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "compaction": {
      "model": "opencode/kimi-k2.5"
    },
    "explore": {
      "model": "opencode/kimi-k2.5"
    },
    "general": {
      "model": "openai/gpt-5.4"
    },
    "title": {
      "model": "opencode/kimi-k2.5"
    },
    "summary": {
      "model": "opencode/kimi-k2.5"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": ""
      },
      "enabled": true
    },
    "tavily": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer "
      },
      "oauth": false
    }
  },
  "autoupdate": true,
  "permission": {
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow"
  },
  "experimental": {
    "disable_paste_summary": true
  },
  "plugin": []
}
